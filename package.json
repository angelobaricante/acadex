    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.3.1",
    "sonner": "^2.0.7",
