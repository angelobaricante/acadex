{
  "name": "acadex",
  "private": true,
  "version": "0.0.0",
  "main": "electron/dist/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json && electron electron/dist/electron/main.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:electron\"",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "package": "npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
